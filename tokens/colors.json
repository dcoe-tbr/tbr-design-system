{
  "$description": "The Brand Report color tokens. Extracted from Figma: https://www.figma.com/design/ocwRrWE9LXuv3hI3m4u435/TBR---Design-System",
  "primitives": {
    "brand": {
      "$description": "Signature TBR orange. The one accent that carries the brand — use sparingly.",
      "10": "#FADFD5",
      "20": "#F7C9B9",
      "30": "#F3AE96",
      "40": "#EF9372",
      "50": "#EB784F",
      "base": "#E75D2C",
      "60": "#C14E25",
      "70": "#9A3E1D",
      "80": "#742F16",
      "90": "#4D1F0F",
      "100": "#2E1309"
    },
    "gray": {
      "$description": "Neutral cool gray ramp. UI chrome, dividers, disabled states, secondary text.",
      "5": "#F6F6F6",
      "10": "#E2E2E2",
      "20": "#CFCFCF",
      "30": "#B8B8B8",
      "40": "#A0A0A0",
      "50": "#888888",
      "base": "#707070",
      "60": "#5D5D5D",
      "70": "#4B4B4B",
      "80": "#383838",
      "90": "#252525",
      "100": "#161616"
    },
    "stone": {
      "$description": "Warm neutral ramp. Editorial surfaces, quotes, card backgrounds with a touch of warmth.",
      "10": "#E5E4E3",
      "20": "#D3D1D0",
      "30": "#BEBBB8",
      "40": "#A8A4A0",
      "50": "#928D89",
      "base": "#7C7671",
      "60": "#67625E",
      "70": "#534F4B",
      "80": "#3E3B39",
      "90": "#292726",
      "100": "#191817"
    },
    "parchment": {
      "$description": "Off-white paper tone. Primary page backgrounds — avoid pure white.",
      "10": "#FDFDFC",
      "20": "#FBFBFA",
      "30": "#FAF9F8",
      "40": "#F8F7F6",
      "50": "#F6F5F3",
      "base": "#F4F3F1",
      "60": "#CBCBC9",
      "70": "#A3A2A1",
      "80": "#7A7A79",
      "90": "#515150",
      "100": "#313130"
    }
  },
  "semantic": {
    "bg": {
      "$description": "Surface layers. bg-01 is the page; bg-02/03 are cards and elevated content.",
      "01": { "value": "#FFFFFF", "ref": "white" },
      "02": { "value": "#F4F3F1", "ref": "parchment.base" },
      "03": { "value": "#E5E4E3", "ref": "stone.10" },
      "inverted": { "value": "#161616", "ref": "gray.100" }
    },
    "text": {
      "primary": { "value": "#1A1A1A", "ref": "near-black" },
      "secondary": { "value": "#707070", "ref": "gray.base" },
      "tertiary": { "value": "#B0B0B0", "ref": "between gray.30 and gray.40" },
      "inverted": { "value": "#FFFFFF", "ref": "white" },
      "brand": { "value": "#E75D2C", "ref": "brand.base" },
      "muted": { "value": "#7C7671", "ref": "stone.base" }
    },
    "border": {
      "light": { "value": "#E6E6E6", "ref": "between gray.10 and gray.20" },
      "default": { "value": "#CFCFCF", "ref": "gray.20" },
      "strong": { "value": "#707070", "ref": "gray.base" }
    },
    "accent": {
      "highlight": { "value": "#E75D2C", "ref": "brand.base" },
      "highlight-hover": { "value": "#C14E25", "ref": "brand.60" },
      "highlight-active": { "value": "#9A3E1D", "ref": "brand.70" },
      "highlight-subtle": { "value": "#FADFD5", "ref": "brand.10" }
    },
    "status": {
      "$description": "Status colors derived from the ramp. TBR is editorial — use these only for functional UI (form errors, toasts), not decorative.",
      "success": "#2E7D32",
      "warning": "#B8860B",
      "danger": "#C14E25",
      "info": "#334155"
    }
  }
}
